<mujoco model="a2 test course with obj meshes">
  <include file="a2.xml"/>

  <statistic center="0 0 0.1" extent="4"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="0" elevation="-25"/>
  </visual>

  <asset>
      <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
      <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
        markrgb="0.8 0.8 0.8" width="300" height="300"/>
      <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="10 10" reflectance="0.2"/>

      <mesh name="umbrella_mesh"  file="umbrella.obj"  scale="0.1 0.1 0.1"/>
      <mesh name="backpack_mesh"  file="backpack.obj"  scale="1 1 1"/>
      <mesh name="wallclock_mesh" file="wallclock.obj" scale="0.01 0.01 0.01"/>

      <texture name="umbrella_tex" type="2d" file="meshes/umbrella.png"/>
      <material name="umbrella_mat" texture="umbrella_tex"/>

      <texture name="wallclock_tex" type="2d" file="meshes/wallclock.png"/>
      <material name="wallclock_mat" texture="wallclock_tex"/>
  </asset>

  <worldbody>
    <light pos="0 0 4" dir="0 0 -1" directional="true"/>
    <geom name="my_simulation_floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="umbrella" pos="2.5 1.5 0">
      <geom type="mesh" mesh="umbrella_mesh" material="umbrella_mat" euler="90 0 0" rgba="0.8 0.1 0.1 1"/>
    </body>

    <body name="backpack" pos="2.5 -1.5 0">
      <geom type="mesh" mesh="backpack_mesh" euler="0 0 -45" rgba="0.2 0.5 0.3 1"/>
    </body>

    <body name="wall_clock" pos="2.5 0 1.0">
      <geom type="mesh" mesh="wallclock_mesh" material="wallclock_mat" euler="0 0 3.14159" rgba="0.9 0.9 0.9 1"/>
    </body>

    <geom pos="6  2   0.5" type="box" size="0.2 1.5 0.5" rgba="0.6 0.4 0.8 1"/>
    <geom pos="6 -2   0.5" type="box" size="0.2 1.5 0.5" rgba="0.6 0.4 0.8 1"/>

    <geom pos="8 -1   0.5" type="box"      size="0.3 0.3 0.5" rgba="0.8 0.3 0.3 1"/>
    <geom pos="9  2   0.4" type="cylinder" size="0.3 0.4"  rgba="0.3 0.6 0.8 1"/>

    <geom pos="12  1.5 0.5" type="box"      size="0.3 0.3 0.5" rgba="0.9 0.7 0.2 1"/>
    <geom pos="12 -1.5 0.5" type="box"      size="0.3 0.3 0.5" rgba="0.9 0.7 0.2 1"/>
    <geom pos="13  0   0.4" type="cylinder" size="0.35 0.4" rgba="0.6 0.4 0.8 1"/>
  </worldbody>
</mujoco>
