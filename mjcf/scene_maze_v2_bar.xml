<mujoco model="a2 maze v2 bar">
  <include file="a2_rotated.xml"/>

  <!--
    Geometry from scene_maze.json (robits blueprint export).
    All walls: half-thickness 0.075 m, half-height 0.75 m (1.5 m tall).

    Outer boundary:
      north  y=+5.2  x∈[-5.4, +2.0]
      east   x=+2.0  y∈[-4.5, +5.2]  (east_hi y∈[0,5.2], east_lo y∈[-4.5,0])
      wing_n y=+4.3  x∈[-10.5,-5.4]
      west   x=-10.5 y∈[-4.5,+4.3]
      south_lo y=-4.5  x∈[-10.5,-2.6]
      south entrance at y=0 — gap x∈[-1.1,+0.8] (1.9 m)

    Interior walls (from JSON):
      hw_a   Y-aligned wall x=-7.9,  y∈[-0.8,+3.2]
      hw_b   X-aligned wall y=+1.54, x∈[-8.0,-4.0]
      hw_c   X-aligned stub x∈[-3.0,-2.6], y≈0
      w2p6_a Y-aligned x=-2.6,  y∈[-4.5,+2.0]
      w2p6_b Y-aligned x=-2.6,  y∈[+2.9,+5.4]
      w5p4_lo_b Y-aligned x=-9.16, y∈[+0.48,+4.28]
      w5p4_hi_a X-aligned x∈[-10.55,-9.05], y≈-0.49
      w5p4_hi_b Y-aligned x=-5.4,  y∈[+3.0,+4.8]
      w6p8_a  Y-aligned x=-7.86, y∈[-4.70,-1.80]
      w6p8_b  Y-aligned x=-4.09, y∈[+1.51,+3.01]
      box_0063 X-aligned dynamic bar x∈[-2.63,+2.17], y=-2.25
  -->

  <statistic center="-4.25 0.35 0.5" extent="7.5"/>

  <visual>
    <headlight diffuse="0.60 0.60 0.60" ambient="0.30 0.30 0.30" specular="0 0 0"/>
    <rgba haze="0.15 0.20 0.25 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.48 0.44 0.40" rgb2="0.36 0.33 0.30" markrgb="0.62 0.58 0.54" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.12"/>
    <material name="wall" rgba="0.76 0.74 0.70 1"/>

    <mesh name="umbrella_mesh"  file="umbrella.obj"  scale="0.1  0.1  0.1"/>
    <mesh name="backpack_mesh"  file="backpack.obj"  scale="1    1    1"/>
    <mesh name="wallclock_mesh" file="wallclock.obj" scale="0.01 0.01 0.01"/>

    <texture name="umbrella_tex"  type="2d" file="meshes/umbrella.png"/>
    <material name="umbrella_mat" texture="umbrella_tex"/>
    <texture name="wallclock_tex" type="2d" file="meshes/wallclock.png"/>
    <material name="wallclock_mat" texture="wallclock_tex"/>
  </asset>

  <worldbody>
    <light pos="-9.0  2.5  4.0" dir="0 0 -1" directional="false" diffuse="0.50 0.48 0.45" specular="0.04 0.04 0.04"/>
    <light pos="-9.0 -2.0  4.0" dir="0 0 -1" directional="false" diffuse="0.50 0.48 0.45" specular="0.04 0.04 0.04"/>
    <light pos="-4.0  3.0  4.0" dir="0 0 -1" directional="false" diffuse="0.50 0.48 0.45" specular="0.04 0.04 0.04"/>
    <light pos="-4.0 -2.0  4.0" dir="0 0 -1" directional="false" diffuse="0.50 0.48 0.45" specular="0.04 0.04 0.04"/>
    <light pos=" 0.0  2.5  4.0" dir="0 0 -1" directional="false" diffuse="0.50 0.48 0.45" specular="0.04 0.04 0.04"/>

    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- ===== Outer boundary ===== -->
    <geom name="north"      material="wall" pos="-1.7   5.2   0.75" type="box" size="3.7   0.075 0.75"/>
    <geom name="east_hi"    material="wall" pos=" 2.0   2.6   0.75" type="box" size="0.075 2.6   0.75"/>
    <geom name="east_lo"    material="wall" pos=" 2.0  -2.25  0.75" type="box" size="0.075 2.25  0.75"/>
    <geom name="step"       material="wall" pos="-5.4   4.75  0.75" type="box" size="0.075 0.45  0.75"/>
    <geom name="wing_n"     material="wall" pos="-7.95  4.3   0.75" type="box" size="2.55  0.075 0.75"/>
    <geom name="west"       material="wall" pos="-10.5  -0.1  0.75" type="box" size="0.075 4.4   0.75"/>
    <geom name="south_lo"   material="wall" pos="-6.55  -4.5  0.75" type="box" size="3.95  0.075 0.75"/>
    <!-- south entrance: gap x∈[-1.1, +0.8] = 1.9 m -->
    <geom name="south_up_w" material="wall" pos="-4.0   0.0   0.75" type="box" size="2.9   0.075 0.75"/>
    <geom name="south_up_e" material="wall" pos=" 1.4   0.0   0.75" type="box" size="0.6   0.075 0.75"/>

    <!-- ===== Interior walls (from scene_maze.json) ===== -->

    <!-- hw_a: Y-aligned vertical wall x=-7.9, y∈[-0.8, +3.2] -->
    <geom name="hw_a"       material="wall" pos="-7.9   1.2   0.75" type="box" size="0.075 2.0   0.75"/>
    <!-- hw_b: X-aligned horizontal wall y=+1.54, x∈[-8.0, -4.0] -->
    <geom name="hw_b"       material="wall" pos="-6.0   1.54  0.75" type="box" size="2.0   0.075 0.75"/>
    <!-- hw_c: small X-aligned stub x∈[-3.0, -2.6] near y=0 -->
    <geom name="hw_c"       material="wall" pos="-2.8   0.0   0.75" type="box" size="0.2   0.075 0.75"/>

    <!-- w2p6: x=-2.6 divider — gap y∈[+2.0,+2.9] (0.9 m) -->
    <geom name="w2p6_a"     material="wall" pos="-2.6  -1.25  0.75" type="box" size="0.075 3.25  0.75"/>
    <geom name="w2p6_b"     material="wall" pos="-2.6   4.15  0.75" type="box" size="0.075 1.25  0.75"/>

    <!-- w5p4_lo_b: Y-aligned wall x=-9.16, y∈[+0.48, +4.28] -->
    <geom name="w5p4_lo_b"  material="wall" pos="-9.16  2.38  0.75" type="box" size="0.075 1.9   0.75"/>
    <!-- w5p4_hi_a: X-aligned wall x∈[-10.55, -9.05], y=-0.49 -->
    <geom name="w5p4_hi_a"  material="wall" pos="-9.8  -0.49  0.75" type="box" size="0.75  0.075 0.75"/>
    <!-- w5p4_hi_b: Y-aligned wall x=-5.4, y∈[+3.0, +4.8] -->
    <geom name="w5p4_hi_b"  material="wall" pos="-5.4   3.9   0.75" type="box" size="0.075 0.9   0.75"/>

    <!-- w6p8_a: Y-aligned wall x=-7.86, y∈[-4.70, -1.80] -->
    <geom name="w6p8_a"     material="wall" pos="-7.86 -3.25  0.75" type="box" size="0.075 1.45  0.75"/>
    <!-- w6p8_b: Y-aligned wall x=-4.09, y∈[+1.51, +3.01] -->
    <geom name="w6p8_b"     material="wall" pos="-4.09  2.26  0.75" type="box" size="0.075 0.75  0.75"/>

    <!-- ===== Additional static bar (from scene.json) ===== -->
    <geom name="box_0063" pos="-0.231348 -2.25 0.15" type="box" size="2.4 0.2 0.2" rgba="0.7843137 0.3921569 0.9411765 1"/>

    <!-- ===== Objects ===== -->

    <body name="umbrella" pos="-10.2 3.0 0.0">
      <geom type="mesh" mesh="umbrella_mesh" material="umbrella_mat" euler="90 0 0" rgba="0.90 0.20 0.10 1"/>
    </body>
    <geom pos="-8.5 -4.03 0.30" type="box"      size="0.30 0.30 0.30" rgba="0.78 0.25 0.20 1"/>
    <geom pos="-6.0 -3.0  0.38" type="cylinder"  size="0.20 0.38"     rgba="0.20 0.62 0.58 1"/>

    <body name="backpack" pos="-4.0 3.5 0.0">
      <geom type="mesh" mesh="backpack_mesh" euler="0 0 135" rgba="0.20 0.50 0.30 1"/>
    </body>
    <geom pos="-3.8 -1.5 0.25" type="box"        size="0.25 0.20 0.25" rgba="0.25 0.40 0.75 1"/>
    <geom pos="-4.0 -3.5 0.38" type="cylinder"   size="0.22 0.38"     rgba="0.88 0.52 0.15 1"/>

    <body name="wall_clock" pos="-1.5 5.12 0.90">
      <geom type="mesh" mesh="wallclock_mesh" material="wallclock_mat" euler="0 0 3.14159" rgba="0.92 0.92 0.92 1"/>
    </body>
    <geom pos="-1.0 3.5 0.38" type="cylinder"   size="0.20 0.38"     rgba="0.85 0.70 0.15 1"/>
    <geom pos=" 0.8 1.5 0.25" type="box"         size="0.25 0.20 0.25" rgba="0.55 0.25 0.75 1"/>
  </worldbody>
</mujoco>
