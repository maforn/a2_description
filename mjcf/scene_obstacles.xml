<mujoco model="a2 obstacle course">
  <include file="a2.xml"/>

  <statistic center="0 0 0.1" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="10 10" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 4" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Close obstacles visible immediately -->
    <geom pos="2.5  1.5  0.4" type="box"      size="0.3 0.3 0.4" rgba="0.8 0.3 0.3 1"/>
    <geom pos="2.5 -1.5  0.4" type="box"      size="0.3 0.3 0.4" rgba="0.3 0.6 0.8 1"/>
    <geom pos="3.5  0    0.5" type="cylinder"  size="0.3 0.5"     rgba="0.9 0.7 0.2 1"/>

    <!-- Mid-range: partial wall with gap -->
    <geom pos="6  2   0.5" type="box" size="0.2 1.5 0.5" rgba="0.6 0.4 0.8 1"/>
    <geom pos="6 -2   0.5" type="box" size="0.2 1.5 0.5" rgba="0.6 0.4 0.8 1"/>
    <!-- gap at y=0, robot must go through or around -->

    <!-- Scattered mid obstacles -->
    <geom pos="5  -3.5 0.4" type="cylinder" size="0.25 0.4" rgba="0.4 0.8 0.4 1"/>
    <geom pos="7   3.5 0.4" type="box"      size="0.35 0.35 0.4" rgba="0.8 0.5 0.3 1"/>
    <geom pos="8  -1   0.5" type="box"      size="0.3 0.3 0.5" rgba="0.8 0.3 0.3 1"/>
    <geom pos="9   2   0.4" type="cylinder" size="0.3 0.4"  rgba="0.3 0.6 0.8 1"/>

    <!-- Far goal area obstacles -->
    <geom pos="12  1.5 0.5" type="box"      size="0.3 0.3 0.5" rgba="0.9 0.7 0.2 1"/>
    <geom pos="12 -1.5 0.5" type="box"      size="0.3 0.3 0.5" rgba="0.9 0.7 0.2 1"/>
    <geom pos="13  0   0.4" type="cylinder" size="0.35 0.4" rgba="0.6 0.4 0.8 1"/>
  </worldbody>
</mujoco>
